{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "vitest/globals"
    ]
  },
  "include": [
    "src/features/tasks/utils/**/*.ts",
    "src/features/calendar/utils/**/*.ts"
  ]
}
